{
  "name": "NexTurn Design Tokens",
  "font": {
    "family": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
    "tailwind": "font-sans",
    "tracking": "tracking-normal",
    "bodyLeading": "leading-6",
    "headingLeading": "leading-tight"
  },
  "icons": {
    "library": "lucide-react",
    "strokeWidth": 2.2,
    "sizes": {
      "xs": 14,
      "sm": 16,
      "md": 20,
      "lg": 24
    }
  },
  "componentSystem": {
    "style": "shadcn-primitives",
    "primitives": [
      "button",
      "input",
      "select",
      "card",
      "drawer",
      "badge",
      "table",
      "empty-state",
      "toolbar"
    ]
  },
  "colors": {
    "light": {
      "background": "slate-50",
      "surface": "white",
      "surfaceMuted": "zinc-50",
      "text": "slate-950",
      "muted": "slate-500",
      "border": "slate-200",
      "borderStrong": "slate-300",
      "accent": "emerald-600",
      "accentHover": "emerald-700",
      "accentSoft": "emerald-50",
      "warning": "amber-500",
      "danger": "rose-600"
    },
    "dark": {
      "background": "slate-950",
      "surface": "slate-900",
      "surfaceMuted": "slate-800",
      "text": "slate-50",
      "muted": "slate-400",
      "border": "slate-800",
      "borderStrong": "slate-700",
      "accent": "emerald-400",
      "accentHover": "emerald-300",
      "accentSoft": "emerald-950",
      "warning": "amber-400",
      "danger": "rose-400"
    }
  },
  "spacing": {
    "pageX": "px-6 md:px-10 xl:px-12",
    "pageY": "py-8 md:py-10",
    "card": "p-5 md:p-6",
    "compactCard": "p-4",
    "stack": "gap-4 md:gap-5",
    "section": "gap-6 md:gap-8"
  },
  "radius": {
    "control": "rounded-lg",
    "card": "rounded-xl",
    "large": "rounded-2xl",
    "pill": "rounded-full"
  },
  "shadow": {
    "card": "shadow-[0_18px_50px_rgba(15,23,42,0.06)]",
    "float": "shadow-[0_24px_70px_rgba(15,23,42,0.10)]",
    "none": "shadow-none"
  },
  "layout": {
    "sidebarWidth": "272px",
    "sidebarCollapsedWidth": "82px",
    "contentMaxWidth": "1500px",
    "drawerWidth": "min(560px, 100vw)",
    "marketCardMin": "320px",
    "catalogCardMin": "210px"
  },
  "motion": {
    "duration": "160ms",
    "easing": "cubic-bezier(0.2, 0.8, 0.2, 1)"
  }
}
